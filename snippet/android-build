ARIA2_BUILD() {
    ARIA2_CODE_GET
    # Android has no /etc/ssl/certs; aria2 should accept --ca-certificate at
    # runtime or use the Termux/Android system store the user points it at.
    ./configure \
        --host=$HOST \
        --build=$BUILD_HOST \
        --prefix=${ARIA2_PREFIX:-'/data/data/com.termux/files/usr'} \
        --with-libz \
        --with-libcares \
        --with-libexpat \
        --without-libxml2 \
        --without-libgcrypt \
        --with-openssl \
        --without-libnettle \
        --without-gnutls \
        --without-libgmp \
        --with-libssh2 \
        --with-sqlite3 \
        --without-jemalloc \
        --without-ca-bundle \
        ARIA2_STATIC=yes \
        --disable-shared \
        --disable-nls \
        ac_cv_func_clock_gettime=yes
    # Bionic folds pthread + clock_gettime into libc, and the NDK ships no
    # libpthread.so / librt.so. autoconf still emits -lpthread / -lrt because
    # configure picks them up on the host probes; strip them out of every
    # generated Makefile before linking aria2c.
    find . -name Makefile -exec sed -i 's/-lpthread\b//g; s/-lrt\b//g' {} +
    make -j$(nproc)
}
