# File name: snippet/android-build
#
# Build helpers that drive the Android NDK toolchain (clang/llvm). Mirrors the
# Linux cross-build helpers but uses NDK target triples and Android-specific
# OpenSSL / autotools knobs. Sourced from aria2-android-cross-build-*.sh.
#

ZLIB_BUILD() {
    mkdir -p $BUILD_DIR/zlib && cd $BUILD_DIR/zlib
    curl -Ls -o - "$ZLIB" | tar zxvf - --strip-components=1
    # zlib's ./configure does not honour --host; CC/AR/RANLIB env vars steer it.
    CHOST=$HOST ./configure \
        --prefix=$PREFIX \
        --static
    make -j$(nproc)
    make install
}

EXPAT_BUILD() {
    mkdir -p $BUILD_DIR/expat && cd $BUILD_DIR/expat
    curl -Ls -o - "$EXPAT" | tar jxvf - --strip-components=1
    ./configure \
        --host=$HOST \
        --build=$BUILD_HOST \
        --prefix=$PREFIX \
        --enable-static \
        --disable-shared \
        --without-examples \
        --without-tests \
        --without-docbook
    make -j$(nproc)
    make install
}

