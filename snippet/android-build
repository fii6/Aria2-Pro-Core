OPENSSL_BUILD() {
    mkdir -p $BUILD_DIR/openssl && cd $BUILD_DIR/openssl
    curl -Ls -o - "$OPENSSL" | tar zxvf - --strip-components=1
    # Reset CC/AR/etc. for OpenSSL: its Configure target injects the right NDK
    # prefix on its own, so we don't want to fight it with our exports.
    env -u CC -u CXX -u AR -u AS -u LD -u RANLIB -u STRIP -u CPP \
        ANDROID_NDK_ROOT="$NDK_ROOT" \
        PATH="$NDK_TOOLCHAIN/bin:$PATH" \
        ./Configure \
            $OPENSSL_ARCH \
            -D__ANDROID_API__=$ANDROID_API \
            --prefix=$PREFIX \
            --openssldir=$PREFIX/ssl \
            no-shared \
            no-tests \
            no-asm
    env -u CC -u CXX -u AR -u AS -u LD -u RANLIB -u STRIP -u CPP \
        ANDROID_NDK_ROOT="$NDK_ROOT" \
        PATH="$NDK_TOOLCHAIN/bin:$PATH" \
        make -j$(nproc)
    env -u CC -u CXX -u AR -u AS -u LD -u RANLIB -u STRIP -u CPP \
        ANDROID_NDK_ROOT="$NDK_ROOT" \
        PATH="$NDK_TOOLCHAIN/bin:$PATH" \
        make install_sw
}

